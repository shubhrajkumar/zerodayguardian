# ── Production Environment ──

# Frontend deployment (Vercel)
VITE_SITE_URL=https://zerodayguardian-delta.vercel.app
VITE_API_URL=https://zerodayguardian-backend.onrender.com
VITE_API_BASE_URL=https://zerodayguardian-backend.onrender.com
BACKEND_PUBLIC_URL=https://zerodayguardian-backend.onrender.com
VITE_APP_NAME=ZeroDay Guardian

# Backend
MONGODB_URI=mongodb+srv://<db-user>:<db-pass>@<cluster-host>/zeroday_guardian?retryWrites=true&w=majority
SESSION_SECRET=replace_with_strong_random_secret
JWT_SECRET=replace_with_strong_random_jwt_secret
CORS_ORIGIN=https://zerodayguardian-delta.vercel.app
APP_BASE_URL=https://zerodayguardian-delta.vercel.app

# Health
HEALTHCHECK_SECRET=replace_with_strong_healthcheck_token

# LLM / AI
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_PROVIDER=local_fallback
LLM_MODE=auto
ROUTING_MODE=failover

