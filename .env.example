NODE_ENV=production

# Backend secure LLM proxy config
LLM_PROVIDER=openai
LLM_MODE=auto
PRIMARY_PROVIDER=openai
FALLBACK_PROVIDER=google
ROUTING_MODE=failover
PROVIDER_PRIORITY=openai,google
PROVIDER_WEIGHTS=openai:80,google:20

LLM_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_OUTPUT_TOKENS=2048
OPENAI_BASE_URL=https://api.openai.com/v1/responses
# Optional OpenAI-compatible gateway alias, for example OpenRouter:
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/responses

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash
GOOGLE_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash-lite
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
LLM_OPS_SECRET=replace_with_strong_ops_token
ALERT_WEBHOOK_URL=
ALERT_MIN_LEVEL=warn
ALERT_COOLDOWN_MS=300000

COST_OPENAI=0.003
COST_GOOGLE=0.0015
LLM_MAX_LATENCY_MS=2200
LLM_CRITICAL_TIMEOUT_MS=25000
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_MS=1000
LLM_RETRY_MAX_MS=4000
LLM_RATE_LIMIT_BACKOFF_MS=1000
LLM_QUEUE_CONCURRENCY=1
LLM_QUEUE_MAX_SIZE=400
LLM_QUEUE_MAX_WAIT_MS=15000
LLM_HEALTH_PROBE_INTERVAL_MS=30000
LLM_HEALTH_PROBE_TIMEOUT_MS=5000
LLM_CB_FAILURE_THRESHOLD=3
LLM_CB_OPEN_MS=30000
LLM_CB_HALF_OPEN_PROBES=2
FREE_TIER_PROVIDER_ORDER=openai,google
PREMIUM_TIER_PROVIDER_ORDER=openai,google

# Backend database + security
DATABASE_URL=mongodb://127.0.0.1:27017/neurobot
# Optional: required only for multi-instance SSE checkpoint store
REDIS_URL=redis://127.0.0.1:6379
MONGODB_DB_NAME=neurobot
SESSION_SECRET=replace_with_strong_random_secret
JWT_SECRET=optional_jwt_secret_for_future_auth
DB_ENCRYPTION_KEY=optional_field_encryption_key
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080,http://192.168.56.1:8080
APP_BASE_URL=http://localhost:8080
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
OAUTH_SUCCESS_REDIRECT=/
OAUTH_FAILURE_REDIRECT=/auth?error=oauth_failed
HEALTHCHECK_SECRET=replace_with_strong_healthcheck_token
TRUST_PROXY=false
VERIFY_LLM_ON_STARTUP=true
STRICT_DEPENDENCY_STARTUP=true
ALLOW_LLM_FALLBACK=true
FORCE_LOCAL_FALLBACK=false
STREAM_HEARTBEAT_MS=20000
STREAM_INIT_TIMEOUT_MS=1800
STREAM_RETRY_MIN_MS=1200
STREAM_RETRY_MAX_MS=3800
STREAM_USE_CHECKPOINT_STORE=true
NEWS_REFRESH_INTERVAL_MS=900000
NEUROBOT_PORT=8787

# Lab sandbox (Docker execution)
LAB_DOCKER_ENABLED=false
LAB_DOCKER_IMAGE=zeroday-lab-sandbox:latest
LAB_DOCKER_NETWORK=bridge
LAB_DOCKER_TIMEOUT_MS=20000
LAB_DOCKER_CPUS=0.5
LAB_DOCKER_MEMORY=256m
LAB_DOCKER_PIDS_LIMIT=128
LAB_ALLOWLIST_HOSTS=target.local
LAB_ALLOWLIST_CIDRS=
LAB_ALLOWED_BINS=

# OpenTelemetry
OTEL_ENABLED=true
OTEL_SERVICE_NAME=neurobot-backend
OTEL_SERVICE_VERSION=1.0.0
# Example: http://otel-collector:4318
OTEL_EXPORTER_OTLP_ENDPOINT=

# Python security scanning API (FastAPI)
PY_API_PORT=9001
VITE_PY_API_URL=http://127.0.0.1:9001
PY_DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/zeroday_guardian
PY_CORS_ORIGINS=http://localhost:8080

# Google Cloud SQL (PostgreSQL) helpers
GCLOUD_SQL_INSTANCE_CONNECTION_NAME=
GCLOUD_SQL_DB_USER=
GCLOUD_SQL_DB_PASS=
GCLOUD_SQL_DB_NAME=
