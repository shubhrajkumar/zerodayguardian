{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "cleanUrls": true,
  "installCommand": "npm run install:vercel",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 60,
      "includeFiles": "backend/**"
    },
    "api/pyapi/[...path].py": {
      "maxDuration": 60,
      "includeFiles": "backend/python/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/|pyapi/).*)",
      "destination": "/index.html"
    }
  ]
}
