{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/pyapi/(.*)",
      "destination": "/api/pyapi/$1"
    },
    {
      "source": "/((?!api/|pyapi/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/[...path].js": {
      "maxDuration": 60
    },
    "api/pyapi/[...path].py": {
      "maxDuration": 60
    }
  }
}
