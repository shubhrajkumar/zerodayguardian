# ============================================================
# ZeroDay Guardian — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values before starting the app.
# Variables marked [REQUIRED] must be set for the app to function.
# All others are optional — the app degrades gracefully without them.
#
# IMPORTANT: Do NOT set NODE_ENV in .env — Vite manages this automatically.
# Setting NODE_ENV in .env causes Vite build warnings.

# Application Identity
VITE_SITE_URL=https://zerodayguardian-delta.vercel.app
VITE_APP_NAME=ZeroDay Guardian

# API URLs
VITE_API_URL=https://your-render-url.onrender.com
BACKEND_PUBLIC_URL=https://your-render-url.onrender.com
VITE_API_BASE_URL=
VITE_PY_API_URL=

# LLM / AI Configuration
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
LLM_PROVIDER=local_fallback
LLM_OPS_SECRET=replace_with_strong_ops_token
PROVIDER_PRIORITY=openrouter,google,openai,deepseek

# Database [REQUIRED]
MONGODB_URI=mongodb+srv://<user>:<pass>@<host>/zeroday_guardian?retryWrites=true&w=majority
MONGODB_DB_NAME=zeroday_guardian

# Auth Secrets [REQUIRED]
SESSION_SECRET=replace_with_strong_random_secret
JWT_SECRET=replace_with_strong_random_jwt_secret
CORS_ORIGIN=https://zerodayguardian-delta.vercel.app
APP_BASE_URL=https://zerodayguardian-delta.vercel.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-render-url.onrender.com/auth/google/callback
ENABLE_GOOGLE_LOCALHOST=false
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Frontend Firebase Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_ENABLE_FIREBASE_AUTH=false

# Firebase Admin (for backend)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# OSINT Integrations
OSINT_WHOIS_PROVIDER=whoisxml
OSINT_WHOIS_API_KEY=
OSINT_GEO_API_KEY=
OSINT_BREACH_API_KEY=
OSINT_SCHEDULER_ENABLED=true

# Lab Sandbox (Docker)
LAB_DOCKER_ENABLED=false

# Telemetry
OTEL_ENABLED=true
OTEL_SERVICE_NAME=zeroday-guardian-backend

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
