NODE_ENV=production

# Built-in ZORVIX rule engine
LLM_PROVIDER=local_fallback
LLM_MODE=auto
ROUTING_MODE=failover
PROVIDER_PRIORITY=openrouter,google,openai,deepseek
PROVIDER_WEIGHTS=openrouter:100,google:60,openai:50,deepseek:40
LLM_OPS_SECRET=replace_with_strong_ops_token
ALERT_WEBHOOK_URL=
ALERT_MIN_LEVEL=warn
ALERT_COOLDOWN_MS=300000

LLM_MAX_LATENCY_MS=2200
LLM_CRITICAL_TIMEOUT_MS=25000
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_MS=1000
LLM_RETRY_MAX_MS=4000
LLM_RATE_LIMIT_BACKOFF_MS=1000
LLM_QUEUE_CONCURRENCY=1
LLM_QUEUE_MAX_SIZE=400
LLM_QUEUE_MAX_WAIT_MS=15000
LLM_HEALTH_PROBE_INTERVAL_MS=30000
LLM_HEALTH_PROBE_TIMEOUT_MS=5000
LLM_CB_FAILURE_THRESHOLD=3
LLM_CB_OPEN_MS=30000
LLM_CB_HALF_OPEN_PROBES=2

# Backend database + security
DATABASE_URL=mongodb://127.0.0.1:27017/zeroday_guardian
# Optional: required only for multi-instance SSE checkpoint store
REDIS_URL=redis://127.0.0.1:6379
MONGODB_DB_NAME=zeroday_guardian
SESSION_SECRET=replace_with_strong_random_secret
JWT_SECRET=replace_with_strong_random_jwt_secret
DB_ENCRYPTION_KEY=optional_field_encryption_key
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080,http://192.168.56.1:8080
APP_BASE_URL=http://localhost:8080
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ENABLE_GOOGLE_LOCALHOST=true
GOOGLE_AUTHORIZED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
GOOGLE_REDIRECT_URI=http://localhost:8080/auth
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_API_TOKEN=
OAUTH_SUCCESS_REDIRECT=/
OAUTH_FAILURE_REDIRECT=/auth?error=oauth_failed
HEALTHCHECK_SECRET=replace_with_strong_healthcheck_token
TRUST_PROXY=false
VERIFY_LLM_ON_STARTUP=true
STRICT_DEPENDENCY_STARTUP=true
ALLOW_LLM_FALLBACK=true
FORCE_LOCAL_FALLBACK=false
STREAM_HEARTBEAT_MS=20000
STREAM_INIT_TIMEOUT_MS=1800
STREAM_RETRY_MIN_MS=1200
STREAM_RETRY_MAX_MS=3800
STREAM_USE_CHECKPOINT_STORE=true
NEWS_REFRESH_INTERVAL_MS=900000
NEUROBOT_PORT=8787

# OSINT integrations
# WHOIS providers: "whoisxml" (default) or "ninjas"
OSINT_WHOIS_PROVIDER=whoisxml
OSINT_WHOIS_API_KEY=
OSINT_WHOIS_BASE_URL=https://www.whoisxmlapi.com/whoisserver/WhoisService
OSINT_GEO_API_KEY=
OSINT_GEO_BASE_URL=https://ipinfo.io
OSINT_BREACH_API_KEY=
OSINT_BREACH_PROVIDER=leakcheck
OSINT_BREACH_BASE_URL=
OSINT_PUBLIC_SHARE_ENABLED=false
OSINT_SHARE_BASE_URL=http://localhost:8080
OSINT_SCHEDULER_ENABLED=true
OSINT_SCHEDULER_INTERVAL_MS=60000
OSINT_SCHEDULER_BATCH_LIMIT=5
OSINT_ALERT_WEBHOOK_URL=
OSINT_ALERT_SLACK_WEBHOOK_URL=
OSINT_ALERT_EMAIL_ENABLED=false
OSINT_SMTP_HOST=
OSINT_SMTP_PORT=587
OSINT_SMTP_USER=
OSINT_SMTP_PASS=
OSINT_SMTP_FROM=
OSINT_SMTP_TO=
OSINT_PDF_TEMPLATE=classic
OSINT_PDF_BRAND_NAME=ZeroDay Guardian OSINT
OSINT_PDF_BRAND_COLOR=#38bdf8
OSINT_PDF_LOGO_BASE64=

# Auth email verification
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_EMAIL_ENABLED=false
AUTH_EMAIL_FROM=
AUTH_EMAIL_USER=
AUTH_EMAIL_APP_PASSWORD=
DIGEST_EMAIL_ENABLED=false
DIGEST_EMAIL_FROM_NAME=ZeroDay Guardian Digest
DIGEST_EMAIL_FROM=
DIGEST_EMAIL_USER=
DIGEST_EMAIL_APP_PASSWORD=
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:support@zerodayguardian.app
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_PORTAL_RETURN_URL=http://localhost:8080/dashboard
AUTH_OTP_PREVIEW_ENABLED=true
# For real OTP email delivery set AUTH_EMAIL_ENABLED=true and provide the
# sender address, Gmail account, and app password above. Keep
# AUTH_OTP_PREVIEW_ENABLED=true in local setups so password reset stays usable
# even before SMTP is configured.
AUTH_SMS_ENABLED=false
AUTH_SMS_FROM=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Frontend Firebase config for src/lib/firebase.ts
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
# Optional if you want to mirror the backend value into Vite at build time.
VITE_GOOGLE_CLIENT_ID=
VITE_ENABLE_GOOGLE_LOCALHOST=true
# Optional frontend diagnostics. Keep disabled unless you're actively
# troubleshooting Firebase in the browser.
VITE_ENABLE_FIREBASE_DIAGNOSTICS=false
# Keep disabled unless the frontend explicitly uses Firebase Auth flows.
VITE_ENABLE_FIREBASE_AUTH=false
# Enable if your network/proxy closes Firestore WebChannel connections.
VITE_FIRESTORE_FORCE_LONG_POLLING=false

# Lab sandbox (Docker execution)
LAB_DOCKER_ENABLED=false
LAB_DOCKER_IMAGE=zeroday-lab-sandbox:latest
LAB_DOCKER_NETWORK=bridge
LAB_DOCKER_TIMEOUT_MS=20000
LAB_DOCKER_CPUS=0.5
LAB_DOCKER_MEMORY=256m
LAB_DOCKER_PIDS_LIMIT=128
LAB_ALLOWLIST_HOSTS=target.local
LAB_ALLOWLIST_CIDRS=
LAB_ALLOWED_BINS=

# OpenTelemetry
OTEL_ENABLED=true
OTEL_SERVICE_NAME=zeroday-guardian-backend
OTEL_SERVICE_VERSION=1.0.0
# Example: http://otel-collector:4318
OTEL_EXPORTER_OTLP_ENDPOINT=

# Python security scanning API (FastAPI)
PY_API_PORT=8000
PY_API_INTERNAL_URL=http://127.0.0.1:8000
PY_DATABASE_URL=sqlite:///./backend/python/local.db
# Leave unset unless you want the browser to bypass the local Vite proxy.
VITE_PY_API_URL=
PY_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Google Cloud SQL (PostgreSQL) helpers
GCLOUD_SQL_INSTANCE_CONNECTION_NAME=
GCLOUD_SQL_DB_USER=
GCLOUD_SQL_DB_PASS=
GCLOUD_SQL_DB_NAME=
