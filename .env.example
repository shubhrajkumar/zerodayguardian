# Local Development
CORS_ORIGIN=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173
APP_BASE_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:10000

# Google OAuth (Optional - for /auth/google)
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:10000/api/auth/google/callback
GOOGLE_AUTHORIZED_ORIGINS=http://localhost:5173

# Password reset email via Gmail SMTP
# Use a Gmail App Password, not your normal Gmail password.
AUTH_EMAIL_ENABLED=true
AUTH_EMAIL_FROM_NAME=ZeroDay Guardian Security
AUTH_EMAIL_FROM=yourgmail@gmail.com
AUTH_EMAIL_USER=yourgmail@gmail.com
AUTH_EMAIL_APP_PASSWORD=your_16_char_gmail_app_password
# Optional legacy aliases also supported by the backend:
# GMAIL_USER=yourgmail@gmail.com
# GMAIL_PASS=your_16_char_gmail_app_password
# Local-only fallback when email is not configured:
AUTH_OTP_PREVIEW_ENABLED=true

# Database (MongoDB Atlas free tier or local)
DATABASE_URL=mongodb://localhost:27017/zerodayguardian
# or DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/zerodayguardian

# Session/JWT (generate secure random 32+ chars)
SESSION_SECRET=your-session-secret-64-chars-min
JWT_SECRET=your-jwt-secret-64-chars-min
DB_ENCRYPTION_KEY=your-32-char-db-key

# Run `cp .env.example .env.local` then edit for local dev
