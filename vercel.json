{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "cleanUrls": true,
  "installCommand": "npm run install:vercel",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!(api|pyapi)(/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
