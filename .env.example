# ZeroDay Guardian environment template
# Copy to `.env` for local development and replace placeholder values where needed.

# App URLs and ports
NODE_ENV=development
HOST=0.0.0.0
PORT=10000
NEUROBOT_PORT=8787
PY_API_PORT=8000
FRONTEND_PORT=8080
APP_BASE_URL=http://localhost:8080
VITE_SITE_URL=http://localhost:8080
BACKEND_PUBLIC_URL=http://127.0.0.1:8787
PUBLIC_SERVER_URL=http://127.0.0.1:8787
PY_API_PUBLIC_URL=http://127.0.0.1:8000/pyapi
VITE_API_BASE_URL=
VITE_PY_API_URL=
VITE_API_PROXY_TARGET=http://127.0.0.1:8787
VITE_PY_API_PROXY_TARGET=http://127.0.0.1:8000
PY_API_INTERNAL_URL=http://127.0.0.1:8000

# CORS
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
PY_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
COOKIE_DOMAIN=
TRUST_PROXY=false

# Database
DATABASE_URL=mongodb://localhost:27017/zerodayguardian
MONGODB_URI=
MONGODB_DB_NAME=zerodayguardian
MONGO_CONNECT_TIMEOUT_MS=8000
PY_DATABASE_URL=sqlite:///./backend/python/local.db
PY_SKIP_CREATE_TABLES=false
SKIP_DB_CONNECTION=false

# Core auth and crypto
SESSION_SECRET=replace-with-a-random-string-at-least-32-characters-long
JWT_SECRET=replace-with-a-random-string-at-least-32-characters-long
JWT_ISSUER=neurobot-backend
JWT_AUDIENCE=neurobot-app
DB_ENCRYPTION_KEY=replace-with-a-random-string-at-least-32-characters-long
AUTH_OTP_PREVIEW_ENABLED=true
AUTH_REQUIRE_EMAIL_VERIFICATION=false

# Firebase client SDK (frontend)
VITE_ENABLE_FIREBASE_AUTH=false
VITE_ENABLE_FIREBASE_DIAGNOSTICS=false
VITE_FIRESTORE_FORCE_LONG_POLLING=false
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_APP_ID=your-firebase-web-app-id
VITE_FIREBASE_MESSAGING_SENDER_ID=your-firebase-sender-id
VITE_GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com

# Firebase Admin SDK (backend / Python)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----\n"

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8787/auth/google/callback
GOOGLE_AUTHORIZED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
ENABLE_GOOGLE_LOCALHOST=true
OAUTH_SUCCESS_REDIRECT=/
OAUTH_FAILURE_REDIRECT=/auth?error=oauth_failed

# Email / SMTP
AUTH_EMAIL_ENABLED=false
AUTH_EMAIL_FROM_NAME=ZeroDay Guardian Security
AUTH_EMAIL_FROM=yourgmail@gmail.com
AUTH_EMAIL_USER=yourgmail@gmail.com
AUTH_EMAIL_APP_PASSWORD=your_16_char_gmail_app_password
GMAIL_USER=
GMAIL_PASS=
DIGEST_EMAIL_ENABLED=false
DIGEST_EMAIL_FROM_NAME=ZeroDay Guardian Digest
DIGEST_EMAIL_FROM=
DIGEST_EMAIL_USER=
DIGEST_EMAIL_APP_PASSWORD=

# AI providers (optional)
LLM_MODE=auto
LLM_PROVIDER=auto
ROUTING_MODE=failover
PRIMARY_PROVIDER=openrouter
FALLBACK_PROVIDER=ollama
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
OLLAMA_BACKUP_BASE_URL=http://127.0.0.1:11434
OLLAMA_BACKUP_MODEL=

# Redis / observability / ops
REDIS_URL=
HEALTHCHECK_SECRET=
OTEL_ENABLED=false
OTEL_SERVICE_NAME=neurobot-backend
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=
LLM_OPS_SECRET=
ALERT_WEBHOOK_URL=
ALERT_MIN_LEVEL=warn
OSINT_ALERT_WEBHOOK_URL=
OSINT_ALERT_SLACK_WEBHOOK_URL=

# OSINT providers and scheduler (optional)
OSINT_WHOIS_API_KEY=
OSINT_WHOIS_BASE_URL=
OSINT_WHOIS_PROVIDER=
OSINT_GEO_API_KEY=
OSINT_GEO_BASE_URL=
OSINT_BREACH_API_KEY=
OSINT_BREACH_PROVIDER=leakcheck
OSINT_BREACH_BASE_URL=
OSINT_PUBLIC_SHARE_ENABLED=false
OSINT_SHARE_BASE_URL=
OSINT_SCHEDULER_ENABLED=true
OSINT_SCHEDULER_INTERVAL_MS=60000
OSINT_SCHEDULER_BATCH_LIMIT=5
OSINT_ALERT_EMAIL_ENABLED=false
OSINT_SMTP_HOST=
OSINT_SMTP_PORT=
OSINT_SMTP_USER=
OSINT_SMTP_PASS=
OSINT_SMTP_FROM=
OSINT_SMTP_TO=
OSINT_PDF_TEMPLATE=classic
OSINT_PDF_BRAND_NAME=ZeroDay Guardian OSINT
OSINT_PDF_BRAND_COLOR=#38bdf8
OSINT_PDF_LOGO_BASE64=

# Python OSINT monitor (optional)
PY_OSINT_MONITOR_ENABLED=true
PY_OSINT_RUN_INTERVAL_SECONDS=21600
PY_OSINT_REQUEST_TIMEOUT_SECONDS=20
PY_OSINT_DELAY_MIN_SECONDS=2.0
PY_OSINT_DELAY_MAX_SECONDS=4.0
PY_OSINT_SOURCE_LIMIT_PER_RUN=40
PY_OSINT_MAX_SOURCES_PER_CYCLE=10
PY_OSINT_CONFIDENCE_THRESHOLD=35
PY_OSINT_DEDUPE_RETENTION_DAYS=30
PY_OSINT_MAX_SUMMARY_CHARS=400
PY_OSINT_MAX_RAW_TEXT_CHARS=1200
PY_OSINT_MAX_ALERTS_PER_CYCLE=20
PY_OSINT_ALLOW_HTTP_SOURCES=false
PY_OSINT_CACHE_TTL_SECONDS=900
PY_RECOMMENDATIONS_CACHE_TTL_SECONDS=120
PY_OSINT_RATE_LIMIT=30
PY_OSINT_RATE_LIMIT_WINDOW_SECONDS=300
PY_OSINT_LOG_FILE=
PY_OSINT_STORAGE_FILE=
PY_OSINT_SOURCES_FILE=
PY_OSINT_USER_AGENT=ZeroDayGuardian-OSINTMonitor/1.0 (+https://example.invalid/contact; public lawful monitoring)
PY_OSINT_RESPECT_ROBOTS=true
PY_OSINT_KEYWORDS=
PY_OSINT_DOMAIN_PATTERNS=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Web push / billing / labs (optional)
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:you@example.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_PORTAL_RETURN_URL=
LAB_DOCKER_ENABLED=false
LAB_DOCKER_IMAGE=zeroday-lab-sandbox:latest
LAB_DOCKER_NETWORK=bridge
LAB_DOCKER_TIMEOUT_MS=20000
LAB_DOCKER_CPUS=0.5
LAB_DOCKER_MEMORY=256m
LAB_DOCKER_PIDS_LIMIT=128
LAB_ALLOWLIST_HOSTS=target.local
LAB_ALLOWLIST_CIDRS=
LAB_ALLOWED_BINS=
