{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "cleanUrls": true,
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/pyapi/(.*)",
      "destination": "/api/pyapi/$1"
    },
    {
      "source": "/((?!api/|pyapi/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/[...path].js": {
      "maxDuration": 60,
      "includeFiles": "backend/**"
    },
    "api/pyapi/[...path].py": {
      "maxDuration": 60,
      "includeFiles": "backend/python/**"
    }
  }
}
